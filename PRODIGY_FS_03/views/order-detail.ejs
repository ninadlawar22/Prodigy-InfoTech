<!DOCTYPE html><html><head><title>Order Tracking</title><link rel="stylesheet" href="/style.css"></head><body><%- include('partials_header') %><div class="page"><h1>Order Tracking</h1><div class="track"><div class="active">Order Placed</div><div class="active">Packed</div><div>Out for Delivery</div><div>Delivered</div></div><h2><%= order.order_number %> - <%= order.status %></h2><% items.forEach(i=>{ %><div class="cart-row"><img src="<%= i.image %>"><h3><%= i.name %></h3><p>Qty: <%= i.quantity %></p><b>₹<%= i.price %></b></div><% }) %></div></body></html>
