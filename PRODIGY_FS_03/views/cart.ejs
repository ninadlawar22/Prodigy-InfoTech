<!DOCTYPE html><html><head><title>Shopping Cart</title><link rel="stylesheet" href="/style.css"></head><body><%- include('partials_header') %>
<div class="page"><h1>Shopping Cart</h1><% if(cart.length===0){ %><div class="empty">Your cart is empty. <a href="/products">Shop now</a></div><% } else { %><% cart.forEach(item=>{ %><div class="cart-row"><img src="<%= item.image %>"><div><h3><%= item.name %></h3><p>₹<%= item.price %></p></div><form method="POST" action="/cart/update/<%= item.id %>"><input type="number" name="quantity" value="<%= item.quantity %>" min="1"><button>Update</button></form><form method="POST" action="/cart/remove/<%= item.id %>"><button class="danger">Remove</button></form></div><% }) %><div class="total"><h2>Total: ₹<%= total %></h2><a href="/checkout" class="primary-link">Checkout</a></div><% } %></div>
</body></html>
